  ],
  "rows": [
    {
      "$id": 1,
      "<8C7DD24D>": "<63E7E33D>",
      "<554EE944>": 170,
      "<DBAF43F0>": "I just stare at my palm"
    },
    {
      "$id": 2,
      "<8C7DD24D>": "<A65207CE>",
      "<554EE944>": 170,
      "<DBAF43F0>": "Remembering the warmth of your hand"
    },
    {
      "$id": 3,
      "<8C7DD24D>": "<842D60CD>",
      "<554EE944>": 170,
      "<DBAF43F0>": "I thought that, no matter when, I could always protect you"
    },
    {
      "$id": 4,
      "<8C7DD24D>": "<33AAA530>",
      "<554EE944>": 170,
      "<DBAF43F0>": "I had convinced myself that was what I wished for"
    },
    {
      "$id": 5,
      "<8C7DD24D>": "<4619322F>",
      "<554EE944>": 170,
      "<DBAF43F0>": "There is nothing left between us"
    },
    {
      "$id": 6,
      "<8C7DD24D>": "<1A3D949F>",
      "<554EE944>": 170,
      "<DBAF43F0>": "I was running from learning that truth"
    },
    {
      "$id": 7,
      "<8C7DD24D>": "<EC8B3A9C>",
      "<554EE944>": 170,
      "<DBAF43F0>": "Even after you left, those feelings wrap around me"
    },
    {
      "$id": 8,
      "<8C7DD24D>": "<021C4F6F>",
      "<554EE944>": 170,
      "<DBAF43F0>": "Having lost everything, I need you"
    },
    {
      "$id": 9,
      "<8C7DD24D>": "<2201EFCA>",
      "<554EE944>": 170,
      "<DBAF43F0>": "When I could no longer see the path ahead and was at a loss"
    },
    {
      "$id": 10,
      "<8C7DD24D>": "<426872E7>",
      "<554EE944>": 170,
      "<DBAF43F0>": "You appeared and guided me"
    },
    {
      "$id": 11,
      "<8C7DD24D>": "<751CAA9A>",
      "<554EE944>": 170,
      "<DBAF43F0>": "Until now, I had confidence I could do anything"
    },
    {
      "$id": 12,
      "<8C7DD24D>": "<E86247B2>",
      "<554EE944>": 170,
      "<DBAF43F0>": "That misunderstanding only makes me more miserable"
    }
  ]
}
