  ],
  "rows": [
    {
      "$id": 1,
      "<8C7DD24D>": "<0E4B3E28>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Before a long-closed door"
    },
    {
      "$id": 2,
      "<8C7DD24D>": "<459B6FA7>",
      "<554EE944>": 124,
      "<DBAF43F0>": "You stand alone"
    },
    {
      "$id": 3,
      "<8C7DD24D>": "<AB24EDA6>",
      "<554EE944>": 124,
      "<DBAF43F0>": "What can you see beyond the door?"
    },
    {
      "$id": 4,
      "<8C7DD24D>": "<354FFE1D>",
      "<554EE944>": 124,
      "<DBAF43F0>": "You will not know until you open it?"
    },
    {
      "$id": 5,
      "<8C7DD24D>": "<3D20453D>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Are you afraid to see what is there?"
    },
    {
      "$id": 6,
      "<8C7DD24D>": "<CFF7C212>",
      "<554EE944>": 124,
      "<DBAF43F0>": "I feel the same way"
    },
    {
      "$id": 7,
      "<8C7DD24D>": "<4CD49732>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Shall we try changing that something?"
    },
    {
      "$id": 8,
      "<8C7DD24D>": "<8D657D33>",
      "<554EE944>": 124,
      "<DBAF43F0>": "With an anxious gaze"
    },
    {
      "$id": 9,
      "<8C7DD24D>": "<C4F2586F>",
      "<554EE944>": 124,
      "<DBAF43F0>": "You are looking at me"
    },
    {
      "$id": 10,
      "<8C7DD24D>": "<12A93586>",
      "<554EE944>": 124,
      "<DBAF43F0>": "What is the voice of your heart saying?"
    },
    {
      "$id": 11,
      "<8C7DD24D>": "<69D28E94>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Will you give up?"
    },
    {
      "$id": 12,
      "<8C7DD24D>": "<489137E3>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Are you afraid of time passing?"
    },
    {
      "$id": 13,
      "<8C7DD24D>": "<245EF21D>",
      "<554EE944>": 124,
      "<DBAF43F0>": "You will not know unless you try"
    },
    {
      "$id": 14,
      "<8C7DD24D>": "<13D0BFA2>",
      "<554EE944>": 124,
      "<DBAF43F0>": "We need the strength to move forward"
    },
    {
      "$id": 15,
      "<8C7DD24D>": "<6C0944B4>",
      "<554EE944>": 124,
      "<DBAF43F0>": "It is okay if it does not reach"
    },
    {
      "$id": 16,
      "<8C7DD24D>": "<54705FFB>",
      "<554EE944>": 124,
      "<DBAF43F0>": "It is okay if we fail"
    },
    {
      "$id": 17,
      "<8C7DD24D>": "<1E59B972>",
      "<554EE944>": 124,
      "<DBAF43F0>": "We will believe in the future and aim for it"
    },
    {
      "$id": 18,
      "<8C7DD24D>": "<CBE7DE7F>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Starting with one sure step"
    },
    {
      "$id": 19,
      "<8C7DD24D>": "<E7D1752F>",
      "<554EE944>": 124,
      "<DBAF43F0>": "The two of us will take each other's hands and begin walking"
    },
    {
      "$id": 20,
      "<8C7DD24D>": "<4B733163>",
      "<554EE944>": 124,
      "<DBAF43F0>": "If there is nothing to serve as a guidepost"
    },
    {
      "$id": 21,
      "<8C7DD24D>": "<A031932A>",
      "<554EE944>": 124,
      "<DBAF43F0>": "I will be by your side"
    },
    {
      "$id": 22,
      "<8C7DD24D>": "<DF013EC3>",
      "<554EE944>": 124,
      "<DBAF43F0>": "If you lose sight of where you are going"
    },
    {
      "$id": 23,
      "<8C7DD24D>": "<8641AECD>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Let us walk together"
    },
    {
      "$id": 24,
      "<8C7DD24D>": "<1A3549D9>",
      "<554EE944>": 124,
      "<DBAF43F0>": "Because there is surely a future there"
    }
  ]
}
